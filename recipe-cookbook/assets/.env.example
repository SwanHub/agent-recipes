# Public — inlined at build time, exposed to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Server-only — never inlined to the client. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=eyJ...service-role-key

# Server-only — GitHub API for seed script (public read).
GITHUB_TOKEN=ghp_...
